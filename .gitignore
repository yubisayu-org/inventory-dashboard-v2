# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude/
.continue/
.agents/
skills-lock.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# netlify
.netlify

# supabase
supabase/.temp/

# one-off migration artifacts — contain customer PII / bank data, never commit
data.sql
migration-report-*.csv

# reference-data imports (bulky, re-importable from source) — e.g. JNE rates CSV
scripts/data/

# typescript
*.tsbuildinfo
next-env.d.ts
